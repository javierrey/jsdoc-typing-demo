{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ESNext",
    "lib": ["ESNext", "DOM", "WebWorker"],
    "allowJs": true,
    "maxNodeModuleJsDepth": 2,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": true,
    "checkJs": false,
    "sourceMap": false,
    "composite": false,
    "strict": true,
    "incremental": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "files": ["globals.d.ts"],
  "include": ["src/**/*.js"],
  "exclude": [
    "_exclude",
    "node_modules",
    "dist",
    "gen",
    "**/*.test.*"
  ]
}
